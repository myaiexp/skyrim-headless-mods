#!/usr/bin/env bash
# skytest - symlink-profile launcher for fast, isolated Skyrim SE mod testing.
#
# Turns the game's Data/ into a symlink pointing at one of several profiles:
#   .profiles/full     your real modded Data (renamed once, never modified)
#   .profiles/vanilla  whitelist symlink-farm: vanilla BSAs+plugins + Address Library + CrashLogger
#   .profiles/test     vanilla + the single mod under test (rebuilt each run)
#
# The ONLY change to the working install is one instant, reversible rename
# (Data -> .profiles/full + a symlink). `skytest uninstall` reverts it exactly.
#
# Usage (run `skytest help`, or `skytest <verb> --help` for examples):
#   skytest                     show current state (default, no args)
#   skytest status              show current state            [--json]
#   skytest init                read-only: show vanilla/mod split + planned migration
#                               [--commit apply it] [--full list excluded mods] [--json]
#   skytest setup-save          launch vanilla (no mod) to BUILD the base test save:
#                               at the menu, console `coc qasmoke`, place any fixtures,
#                               then `save SkytestBase`, quit. Used by the autoload below.
#   skytest test <mod> [--with a.dll,b.dll]
#                               launch vanilla + that mod. If the base save exists, boots
#                               straight into it (Start On Save autoload); else to the menu.
#                               Restores to full on exit. `skytest <mod>` is a shortcut.
#   skytest play                launch the FULL modded game over the fast direct path
#   skytest normal              force Data -> full (recover after a crash)
#   skytest uninstall           revert to the original real Data/ directory
#
# v2 "boot into a test save": a test run injects powerofthree's Start On Save (a
# DLL-only, Address-Library-only SKSE plugin) into the TEST profile and pins its
# "Save File" to the base save built by --setup-save, so launch lands in-world with
# the character controllable. Start On Save lives ONLY in the test profile (not in
# vanilla) so --setup-save stays at the menu. Hold SHIFT while the gear spins to skip
# autoload into the menu. The base save is made in vanilla+base only, so it loads under
# any vanilla+1 test. (base-skse/ holds the DLL + ini template; see README.)

set -euo pipefail
shopt -s nullglob

# Resolve through symlinks so PATH installs (e.g. ~/.local/bin/skytest -> repo) still
# find base-skse/ in the real script directory, not the symlink's location.
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# One canonical Steam base. Proton, the (now-unused) launch-skse.sh, and the absorbed
# headless backend all already point here; deriving every path from STEAM kills the old
# dual /.steam/steam vs /.local/share/Steam scheme (they symlink to the same install).
# SKYDIR is the game dir (was ROOT).
STEAM="/home/mse/.local/share/Steam"
APPID="489830"
SKYDIR="$STEAM/steamapps/common/Skyrim Special Edition"
PROTON="$STEAM/steamapps/common/Proton - Experimental/proton"
LOADER="$SKYDIR/skse64_loader.exe"
DATA="$SKYDIR/Data"
PROFILES="$SKYDIR/.profiles"
FULL="$PROFILES/full"
VANILLA="$PROFILES/vanilla"
TEST="$PROFILES/test"
CCC="$SKYDIR/Skyrim.ccc"
PREFIX="$STEAM/steamapps/compatdata/$APPID/pfx/drive_c/users/steamuser"
PLUGINS_TXT="$PREFIX/AppData/Local/Skyrim Special Edition/Plugins.txt"
SAVES_DIR="$PREFIX/Documents/My Games/Skyrim Special Edition/Saves"

# The gamescope test-session backend (sourced, never executed). Provides gs_launch /
# gs_wait_ready / gs_shot / gs_drive / gs_stop / gs_session_alive — all operating on one
# detached gamescope session. Needs SCRIPT_DIR + PREFIX (above) and the helpers below;
# its functions only run after those exist. See lib/gamescope.sh + docs/headless-findings.md.
# shellcheck source=lib/gamescope.sh
source "$SCRIPT_DIR/lib/gamescope.sh"

# Base test save (built by --setup-save) and the Start On Save autoload plugin.
BASE_SAVE_NAME="SkytestBase"
SOS_DLL="$SCRIPT_DIR/base-skse/po3_StartOnSave.dll"
SOS_INI_TEMPLATE="$SCRIPT_DIR/base-skse/po3_StartOnSave.ini.template"

# SkytestProbe — the runtime probe toolkit (DLL-only, Address-Library-only). Injected
# into the test profile unconditionally (no save-existence condition); ini copied
# verbatim (no sed). Read straight from its build output (the canonical copy — no
# vendored duplicate); build it with mods/SkytestProbe/build.sh.
PROBE_DLL="$REPO_ROOT/mods/SkytestProbe/build/SkytestProbe.dll"
PROBE_INI_TEMPLATE="$REPO_ROOT/mods/SkytestProbe/SkytestProbe.ini"

BASE_MASTERS=(Skyrim.esm Update.esm Dawnguard.esm HearthFires.esm Dragonborn.esm)

say()  { printf 'skytest: %s\n' "$*"; }
# die: runtime failure (exit 1). usage_err: bad invocation (exit 2). Both -> stderr,
# both take an optional second arg printed as a "Try:" next-step line (AXI #6).
die()  { printf 'skytest: ERROR: %s\n' "$1" >&2; [ -n "${2:-}" ] && printf 'Try: %s\n' "$2" >&2; exit 1; }
usage_err() { printf 'skytest: %s\n' "$1" >&2; [ -n "${2:-}" ] && printf 'Try: %s\n' "$2" >&2; exit 2; }
jbool() { [ "$1" = 1 ] && printf true || printf false; }
# Emit a JSON array of strings from stdin (one per line; blank lines ignored).
json_arr() {
  local first=1 line out="["
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    line=${line//\\/\\\\}; line=${line//\"/\\\"}
    [ "$first" = 1 ] && first=0 || out+=","
    out+="\"$line\""
  done
  printf '%s]' "$out"
}

# Is a Skyrim game process running? Match the SkyrimSE.exe *cmdline*, not the comm:
# a wine/proton game's comm is often "Main", so the old `pgrep -i skyrimse` (comm-match)
# silently MISSED an already-running game and let a doomed 2nd launch proceed — Steam
# blocks a 2nd instance of the appid, so the gamescope session came up empty/black and
# the shared-channel probe answered `ready` about the *other* game (findings #12/#13).
# The gamescope/proton launcher references skse64_loader.exe (not SkyrimSE.exe), so it's
# matched only once the game actually spawns. Self/parent excluded so the cmdline grep
# can't self-match (findings #11). Echoes the matching pid(s), newest-relevant first.
running_game_pids() { pgrep -f 'SkyrimSE\.exe' 2>/dev/null | grep -vw "$$" | grep -vw "${PPID:-0}" || true; }
game_running() { [ -n "$(running_game_pids | head -1)" ]; }

# Refuse up front when a Skyrim is already running — the #1 source of "why is my test
# black?" confusion: a 2nd instance can't launch (Steam blocks the appid), so the session
# is empty. Names the pid so you can spot a stray/orphaned one.
guard_no_running_game() {
  local p; p="$(running_game_pids | head -1)"
  [ -n "$p" ] && die "Skyrim is already running (pid $p) — close it first; a 2nd instance can't launch." "close that game, then re-run"
  return 0
}

# Where the real, full Data currently lives: FULL if migrated, else DATA.
src_data() { if [ -L "$DATA" ]; then printf '%s' "$FULL"; else printf '%s' "$DATA"; fi; }

# Shared SKSE launch core: every launch path (direct play, gamescope test, setup-save)
# runs the same `"$PROTON" run "$LOADER"`. This prepares its environment — cd to the
# game dir + export the Steam-compat vars — but deliberately does NOT exec/launch:
# the caller decides to exec (play), wrap it under gamescope (test), or run-and-poll
# (setup-save). A function that exec'd couldn't be a gamescope `--` argv, and the
# pgrep-hold paths must keep their shell alive. SteamGameId is set on purpose: the
# headless path needed it and it's harmless to the direct path (merge design §Launch core).
skse_env_export() {
  cd "$SKYDIR" || die "game dir not found: $SKYDIR"
  export STEAM_COMPAT_DATA_PATH="$STEAM/steamapps/compatdata/$APPID"
  export STEAM_COMPAT_CLIENT_INSTALL_PATH="$STEAM"
  export SteamAppId="$APPID"
  export SteamGameId="$APPID"
}

# Preflight for any launch path: proton + the SKSE loader must exist (replaces the old
# `[ -x launch-skse.sh ]` guard now that skytest no longer shells out to that script).
skse_launch_ready() { [ -x "$PROTON" ] && [ -f "$LOADER" ]; }

# The only safety net for the detached test model: refuse whenever a gamescope test
# session is live and the verb would either launch a second one (double-parking Data)
# or unpark Data -> full out from under it (the cross-profile crash — SKSE plugins from
# one profile, ESPs/save from another). Applied wherever Data would move or a launch
# would start. Checked BEFORE game_running so its clearer message wins (the live test
# session is itself a running SkyrimSE.exe, so game_running is true too).
guard_no_live_session() {
  gs_session_alive && die "a test session is live (pid $(gs_session_pid))" "skytest stop"
  return 0
}

# --- classification (whitelist) ----------------------------------------------

# vanilla plugin basenames present in $1 (base masters + Skyrim.ccc, CRLF-safe)
collect_vanilla_plugins() {
  local src="$1" p b f
  local -A van=()
  for p in "${BASE_MASTERS[@]}"; do van["${p,,}"]=1; done
  if [ -f "$CCC" ]; then
    while IFS= read -r p || [ -n "$p" ]; do
      p="${p%$'\r'}"; [ -n "$p" ] || continue
      van["${p,,}"]=1
    done < "$CCC"
  fi
  for f in "$src"/*.es[mlp]; do
    b=$(basename "$f")
    [ -n "${van[${b,,}]:-}" ] && printf '%s\n' "$b"
  done
  return 0
}

# vanilla BSA basenames present in $1 (Skyrim - *, cc*, _ResourcePack*)
collect_vanilla_bsas() {
  local src="$1" f b
  shopt -s nocasematch
  for f in "$src"/*.bsa; do
    b=$(basename "$f")
    if [[ "$b" =~ ^(Skyrim\ -|cc|_ResourcePack) ]]; then printf '%s\n' "$b"; fi
  done
  shopt -u nocasematch
  return 0
}

# base SKSE files every C++ test needs: Address Library + CrashLogger (+ its config)
collect_base_skse() {
  local src="$1/SKSE/Plugins" f
  [ -d "$src" ] || return 0
  for f in "$src"/versionlib*.bin "$src"/CrashLogger*; do printf '%s\n' "$(basename "$f")"; done
  return 0
}

# --- profile building --------------------------------------------------------

build_vanilla_profile() {
  local b f
  rm -rf "$VANILLA"
  mkdir -p "$VANILLA/SKSE/Plugins"
  while IFS= read -r b; do ln -s "$FULL/$b" "$VANILLA/$b"; done < <(collect_vanilla_plugins "$FULL")
  while IFS= read -r b; do ln -s "$FULL/$b" "$VANILLA/$b"; done < <(collect_vanilla_bsas "$FULL")
  while IFS= read -r f; do ln -s "$FULL/SKSE/Plugins/$f" "$VANILLA/SKSE/Plugins/$f"; done < <(collect_base_skse "$FULL")
}

build_test_profile() {
  local mod="$1" deps="${2:-}"
  rm -rf "$TEST"
  cp -a "$VANILLA/." "$TEST/"            # copy the vanilla symlink-farm (links preserved)
  if [ -f "$mod" ]; then
    # a single build artifact: place it where it installs in Data
    case "$mod" in
      *.dll)     ln -sfn "$mod" "$TEST/SKSE/Plugins/$(basename "$mod")" ;;
      *.es[mlp]) ln -sfn "$mod" "$TEST/$(basename "$mod")" ;;
      *) die "don't know where to place file: $mod" ;;
    esac
  else
    # a Data-shaped folder: mirror its layout exactly
    local f rel
    while IFS= read -r -d '' f; do
      rel="${f#"$mod"/}"
      mkdir -p "$TEST/$(dirname "$rel")"
      ln -sfn "$f" "$TEST/$rel"
    done < <(find "$mod" -type f -print0)
  fi
  # optional extra framework DLLs pulled from the full profile
  if [ -n "$deps" ]; then
    local d match
    IFS=',' read -ra arr <<< "$deps"
    for d in "${arr[@]}"; do
      d="${d// /}"; [ -n "$d" ] || continue
      for match in "$FULL/SKSE/Plugins/$d"*; do
        ln -sfn "$match" "$TEST/SKSE/Plugins/$(basename "$match")"
      done
    done
  fi
}

# --- Data symlink switching (atomic) -----------------------------------------

point_data() {                            # point_data full|vanilla|test
  local tgt="$PROFILES/$1"
  [ -d "$tgt" ] || die "profile not found: $1"
  ln -s "$tgt" "$DATA.swap.$$"
  mv -T "$DATA.swap.$$" "$DATA"
}

backup_plugins()  { [ -f "$PLUGINS_TXT" ] && cp -f "$PLUGINS_TXT" "$PROFILES/Plugins.txt.bak"; }
restore_plugins() { [ -f "$PROFILES/Plugins.txt.bak" ] && cp -f "$PROFILES/Plugins.txt.bak" "$PLUGINS_TXT"; }

write_test_plugins() {
  local mod="$1" f
  {
    echo "# Generated by skytest (test profile) - do not keep"
    if [ -f "$mod" ]; then
      case "$mod" in *.es[mlp]) echo "*$(basename "$mod")" ;; esac
    else
      while IFS= read -r -d '' f; do echo "*$(basename "$f")"; done \
        < <(find "$mod" -maxdepth 2 -type f \( -iname '*.esp' -o -iname '*.esl' -o -iname '*.esm' \) -print0)
    fi
  } > "$PLUGINS_TXT"
}

# vanilla-only Plugins.txt (for --setup-save): base masters + Skyrim.ccc entries.
write_vanilla_plugins() {
  {
    echo "# Generated by skytest (vanilla setup) - do not keep"
    while IFS= read -r b; do echo "*$b"; done < <(collect_vanilla_plugins "$VANILLA")
  } > "$PLUGINS_TXT"
}

base_save_exists() { [ -f "$SAVES_DIR/$BASE_SAVE_NAME.ess" ]; }

# Inject Start On Save into the TEST profile and pin it to the base save, so launch
# autoloads straight into the prepared scene. Only call when the base save exists.
inject_startonsave() {
  [ -f "$SOS_DLL" ] || die "Start On Save DLL missing at $SOS_DLL"
  [ -f "$SOS_INI_TEMPLATE" ] || die "Start On Save ini template missing at $SOS_INI_TEMPLATE"
  mkdir -p "$TEST/SKSE/Plugins"
  ln -sfn "$SOS_DLL" "$TEST/SKSE/Plugins/po3_StartOnSave.dll"
  sed "s/@BASE_SAVE@/$BASE_SAVE_NAME/" "$SOS_INI_TEMPLATE" > "$TEST/SKSE/Plugins/po3_StartOnSave.ini"
}

# Inject SkytestProbe into the TEST profile, unconditionally (mirrors the StartOnSave
# symlink injection but with NO save-existence condition; the ini is copied verbatim,
# no sed substitution). Gives every isolated test the runtime probe toolkit — CC writes
# probe specs to commands.jsonl, the running game writes traces to trace.jsonl (both under
# the SKSE log dir's skytest/). Degrades to a warning (not a hard failure) if the DLL
# hasn't been built yet, so skytest still works without it.
inject_skytestprobe() {
  if [ ! -f "$PROBE_DLL" ]; then
    say "note: SkytestProbe DLL absent at $PROBE_DLL — skipping probe injection (build it in ~/Projects/skyrim-headless-mods/mods/SkytestProbe)."
    return 0
  fi
  mkdir -p "$TEST/SKSE/Plugins"
  ln -sfn "$PROBE_DLL" "$TEST/SKSE/Plugins/SkytestProbe.dll"
  [ -f "$PROBE_INI_TEMPLATE" ] && cp -f "$PROBE_INI_TEMPLATE" "$TEST/SKSE/Plugins/SkytestProbe.ini"
}

# --- commands ----------------------------------------------------------------

cmd_init() {
  local commit="" full="" json=""
  for a in "$@"; do
    case "$a" in
      --commit) commit=1 ;;
      --full)   full=1 ;;
      --json)   json=1 ;;
      *) usage_err "init: unknown option: $a" "skytest init --help" ;;
    esac
  done
  local src; src=$(src_data)
  [ -d "$src" ] || die "Data dir not found at $src"

  local nplug nbsa ndll migrated
  nplug=$(collect_vanilla_plugins "$src" | wc -l)
  nbsa=$(collect_vanilla_bsas "$src" | wc -l)
  ndll=$(find "$src/SKSE/Plugins" -maxdepth 1 -name '*.dll' 2>/dev/null | wc -l)
  [ -L "$DATA" ] && migrated=1 || migrated=0

  local excluded nexcl
  excluded=$(comm -23 \
    <(for f in "$src"/*.es[mlp]; do basename "$f"; done | sort -f) \
    <(collect_vanilla_plugins "$src" | sort -f))
  nexcl=$(grep -c . <<<"$excluded" || true)

  if [ -n "$json" ]; then
    printf '{"source":"%s","migrated":%s,"vanilla_plugins":%s,"vanilla_bsas":%s,"startup_dlls":%s,"excluded_count":%s,"base_skse":%s,"excluded_mods":%s}\n' \
      "$src" "$(jbool "$migrated")" "$nplug" "$nbsa" "$ndll" "$nexcl" \
      "$(collect_base_skse "$src" | json_arr)" \
      "$(json_arr <<<"$excluded")"
    return 0
  fi

  echo "skytest init — read-only classification (nothing changed)"
  printf '%-12s %s\n' source "$src"
  printf '%-12s %s\n' migrated "$([ "$migrated" = 1 ] && echo yes || echo no)"
  echo
  printf '%-12s %s plugins, %s BSAs\n' vanilla "$nplug" "$nbsa"
  printf '%-12s %s\n' "base SKSE" "$(collect_base_skse "$src" | tr '\n' ' ')"
  printf '%-12s %s now → ~1 (CrashLogger) + mod under test\n' "startup DLL" "$ndll"
  echo
  if [ -n "$full" ]; then
    echo "excluded from tests ($nexcl mod plugins):"
    grep . <<<"$excluded" | sed 's/^/  - /'
  else
    echo "excluded from tests: $nexcl mod plugins  (use --full to list)"
  fi

  if [ -z "$commit" ]; then
    echo
    echo "Would migrate on \`init --commit\`:"
    echo "  1. mv Data → .profiles/full   2. ln -s full → Data   3. build vanilla (symlinks)"
    echo "  reverse any time: skytest uninstall"
    echo
    echo "Next steps:"
    echo "  skytest init --commit     apply the migration"
    echo "  skytest init --full       list the excluded mod plugins"
    return 0
  fi

  # --- commit: the one sensitive step, each part verified ---
  guard_no_running_game
  [ -L "$DATA" ] && die "already migrated (Data is a symlink). Nothing to do."
  [ -d "$DATA" ] || die "Data is not a real directory; aborting."

  local before_count before_du
  before_count=$(find "$DATA" -mindepth 1 | wc -l)
  before_du=$(du -sb "$DATA" | cut -f1)
  say "pre-flight: $before_count entries, $before_du bytes"

  mkdir -p "$PROFILES"
  backup_plugins
  cp -f "$PLUGINS_TXT" "$PROFILES/Plugins.txt.orig" 2>/dev/null || true
  say "backed up Plugins.txt"

  mv "$DATA" "$FULL"
  ln -s "$FULL" "$DATA"
  say "Data -> .profiles/full symlink created"

  [ -L "$DATA" ] || die "verify failed: Data is not a symlink"
  local after_count after_du
  after_count=$(find -L "$DATA" -mindepth 1 | wc -l)
  after_du=$(du -sbL "$DATA" | cut -f1)
  [ "$before_count" = "$after_count" ] || die "verify failed: entry count changed ($before_count -> $after_count)" "skytest uninstall"
  [ "$before_du" = "$after_du" ] || die "verify failed: size changed" "skytest uninstall"
  say "verified: entry count + size unchanged through the symlink"

  build_vanilla_profile
  say "vanilla profile built: $(find "$VANILLA" -type l | wc -l) symlinks"

  echo
  say "DONE. Launch your normal modded game once to confirm it loads identically."
  echo
  echo "Next steps:"
  echo "  skytest play              launch the full modded game (fast path)"
  echo "  skytest setup-save        build the base test save for autoload"
  echo "  skytest uninstall         restore the byte-identical original Data/"
}

# Launch SKSE and hold the current Data profile until the real game PID exits.
# $1 = a short label for the "locked" message. Honors SKYTEST_NO_LAUNCH.
launch_and_hold() {
  local label="$1"
  if [ -n "${SKYTEST_NO_LAUNCH:-}" ]; then
    say "profile built. SKYTEST_NO_LAUNCH set - skipping launch."
    return 0
  fi

  say "Launching SKSE..."
  skse_env_export                  # cd $SKYDIR + Steam-compat env (shared launch core)
  "$PROTON" run "$LOADER" || true  # the loader exits in ~2s; the real game lives on (we poll for it below)

  # The loader and an early launcher stub flash and die within a second or two,
  # and they also match a 'skyrimse' name search. If we restored on their exit
  # we'd swap Data mid-launch (SKSE plugins read from one profile, ESPs/save from
  # 'full' -> crash). So: lock onto a process that SURVIVES a grace window (the
  # real game lives for minutes), and hold until exactly that PID exits.
  local grace=10 timeout=240 waited=0 real_pid="" pid g ok
  say "waiting for the game to stabilize (ignoring the launcher flash)..."
  while [ "$waited" -lt "$timeout" ]; do
    if game_running; then
      pid=$(running_game_pids | head -n1)
      ok=1; g=0
      while [ "$g" -lt "$grace" ]; do
        kill -0 "$pid" 2>/dev/null || { ok=0; break; }
        sleep 1; g=$((g+1)); waited=$((waited+1))
      done
      [ "$ok" = 1 ] && { real_pid="$pid"; break; }
    else
      sleep 2; waited=$((waited+2))
    fi
  done

  if [ -n "$real_pid" ]; then
    say "game up (pid $real_pid) - $label"
    while kill -0 "$real_pid" 2>/dev/null; do sleep 3; done
    say "game exited."
  else
    say "WARNING: game never stabilized within ${timeout}s - launch may have failed."
  fi
}

# A test session runs the game under gamescope so it is drivable + screenshot-able,
# and is DETACHED: launch -> wait for in-world -> return, so CC can issue shot/drive/
# ready as separate commands. There is no EXIT-trap restore (a detached session can't
# be trap-covered) — `skytest stop` tears down AND restores Data -> full.
cmd_test() {
  local mod="" deps="" backend="wayland"
  local usage="skytest test <mod-dir-or-file> [--with a.dll,b.dll] [--headless]"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --headless) backend="headless"; shift ;;
      --sdl)      backend="sdl"; shift ;;   # visible fallback if --backend wayland misbehaves under Hyprland
      --with)     deps="${2:-}"; shift 2 2>/dev/null || shift ;;
      -*)         usage_err "test: unknown option: $1" "$usage" ;;
      *)          if [ -z "$mod" ]; then mod="$1"; else usage_err "test: unexpected arg: $1" "$usage"; fi; shift ;;
    esac
  done

  [ -n "$mod" ] || usage_err "test: missing mod path" "$usage"
  [ -L "$DATA" ] || die "not migrated yet." "skytest init --commit"
  [ -e "$mod" ] || usage_err "mod path not found: $mod" "$usage"
  # Refuse BEFORE rebuilding/parking the profile — a second launch over a live session
  # would double-park Data with no trap to undo it (detached model has no auto-restore).
  guard_no_live_session
  guard_no_running_game
  skse_launch_ready || die "proton or skse64_loader.exe missing" "check $PROTON and $LOADER"

  say "building test profile: vanilla + $(basename "$mod")${deps:+ + deps[$deps]}"
  build_test_profile "$mod" "$deps"
  inject_skytestprobe          # runtime probe toolkit, every test (unconditional)
  backup_plugins

  if base_save_exists; then
    inject_startonsave
    say "base save '$BASE_SAVE_NAME' found - autoloading it on launch (hold SHIFT to skip to menu)."
  else
    say "no base save '$BASE_SAVE_NAME.ess' - launching to the menu (use a NEW GAME). Build one with: skytest setup-save"
  fi

  write_test_plugins "$mod"
  point_data test
  say "Data -> test."

  gs_launch "$backend"

  if [ -n "${SKYTEST_NO_LAUNCH:-}" ]; then
    point_data full; restore_plugins
    say "(SKYTEST_NO_LAUNCH) built + injected + swapped profile, then restored Data -> full. No game launched."
    return 0
  fi

  local rc=0; gs_wait_ready || rc=$?
  case "$rc" in
    2) die "test session died during boot - check $GS_LOG" "skytest stop" ;;
    1) say "WARNING: not in-world yet (timed out); the session is still live — retry: skytest ready" ;;
  esac
  say "test session live ($backend). Drive it:  skytest shot <out.png> | skytest drive seq down down enter"
  say "when done:  skytest stop   (tears down + restores Data -> full)"
}

# ready / shot / drive / stop — operate on the running gamescope test session that
# `cmd_test` launched. They error cleanly when no session/socket is up.
cmd_ready() {
  gs_session_alive || die "no live test session to wait on" "skytest test <mod>"
  gs_wait_ready "$@"
}
cmd_shot()  { gs_shot "$@"; }
cmd_drive() {
  # A stale gamescope-0-ei socket can outlive a dead session, so the socket file alone
  # isn't proof of life — require a live session (then gs_drive validates the socket).
  gs_session_alive || die "no live test session to drive" "skytest test <mod>"
  gs_drive "$@"
}
cmd_stop() {
  gs_session_alive || die "no live test session to stop" "skytest status"
  gs_stop || true                      # gs_stop warns on its own stderr if a straggler survived
  point_data full
  restore_plugins
  say "restored: Data -> full, Plugins.txt restored"
}

cmd_setup_save() {
  [ -L "$DATA" ] || die "not migrated yet." "skytest init --commit"
  guard_no_live_session   # would launch a 2nd game over the live test session
  guard_no_running_game
  skse_launch_ready || die "proton or skse64_loader.exe missing" "check $PROTON and $LOADER"
  [ -d "$VANILLA" ] || die "vanilla profile missing." "skytest init --commit"

  if base_save_exists; then
    say "NOTE: base save '$BASE_SAVE_NAME.ess' already exists; saving again will overwrite it."
  fi

  # Vanilla only, NO Start On Save -> we land at the menu and drive setup by hand.
  backup_plugins
  trap 'point_data full; restore_plugins; say "restored: Data -> full, Plugins.txt restored"' EXIT INT TERM
  write_vanilla_plugins
  point_data vanilla

  echo
  say "=== building the base test save (vanilla + base SKSE only) ==="
  say "At the main menu, open the console (~) and:"
  say "   coc qasmoke           # jump straight into Bethesda's dev hall (skips intro)"
  say "   <place any fixtures>  # e.g. spawn/grab a vanilla NPC, click it, setplayerteammate 1"
  say "   save $BASE_SAVE_NAME  # exact name - this is what test runs autoload"
  say "Then quit to desktop. Use ONLY vanilla content so the save loads under any test."
  echo

  launch_and_hold "setup session - save as '$BASE_SAVE_NAME' then quit."

  if base_save_exists; then
    say "base save '$BASE_SAVE_NAME.ess' captured. 'skytest test <mod>' will now boot into it."
    echo
    echo "Next steps:"
    echo "  skytest test <mod>        launch a mod, booting into the base save"
  else
    say "WARNING: no '$BASE_SAVE_NAME.ess' found - did the in-game 'save $BASE_SAVE_NAME' run?"
    echo
    echo "Next steps:"
    echo "  skytest setup-save        retry — remember to 'save $BASE_SAVE_NAME' before quitting"
  fi
}

cmd_normal() {
  if [ ! -L "$DATA" ]; then say "already normal — Data is the real directory."; return 0; fi
  guard_no_live_session   # forcing Data -> full under a live test session = cross-profile crash
  point_data full; restore_plugins; say "Data → full"
}

cmd_play() {
  # Everyday fast launch of the FULL modded game over the direct SKSE path
  # (skips Steam Play, which is the real cause of the slow ~2min startup).
  guard_no_live_session   # unparking Data -> full out from under a live test session = crash
  guard_no_running_game   # a 2nd instance can't launch anyway — say so cleanly
  if [ -L "$DATA" ]; then
    [ "$(readlink "$DATA")" = "$TEST" ] && { say "recovering an interrupted test run..."; restore_plugins; }
    point_data full
  fi
  if [ -n "${SKYTEST_NO_LAUNCH:-}" ]; then say "would launch full modded game (NO_LAUNCH set)"; return 0; fi
  say "launching full modded game via the fast direct path..."
  skse_env_export                  # cd $SKYDIR + Steam-compat env (shared launch core)
  exec "$PROTON" run "$LOADER"     # blocking, no gamescope — the daily-driver fast path
}

cmd_status() {
  local json=""; [ "${1:-}" = "--json" ] && json=1
  local migrated tgt base hf hv ht sess_pid=""
  if [ -L "$DATA" ]; then migrated=1; tgt=$(basename "$(readlink "$DATA")"); else migrated=0; tgt=""; fi
  base_save_exists && base=1 || base=0
  [ -d "$FULL" ]    && hf=1 || hf=0
  [ -d "$VANILLA" ] && hv=1 || hv=0
  [ -d "$TEST" ]    && ht=1 || ht=0
  gs_session_alive  && sess_pid="$(gs_session_pid)"   # live detached gamescope test session?

  if [ -n "$json" ]; then
    printf '{"migrated":%s,"data_target":"%s","profiles":{"full":%s,"vanilla":%s,"test":%s},"base_save":%s,"session":{"alive":%s,"pid":"%s"}}\n' \
      "$(jbool "$migrated")" "$tgt" "$(jbool "$hf")" "$(jbool "$hv")" "$(jbool "$ht")" "$(jbool "$base")" \
      "$([ -n "$sess_pid" ] && echo true || echo false)" "$sess_pid"
    return 0
  fi

  echo "skytest — isolated Skyrim SE mod-test launcher"
  printf '%-10s %s\n' data "$DATA"
  if [ "$migrated" = 1 ]; then
    local profs=""
    [ "$hf" = 1 ] && profs+="full "; [ "$hv" = 1 ] && profs+="vanilla "; [ "$ht" = 1 ] && profs+="test "
    printf '%-10s migrated → %s\n' state "$tgt"
    printf '%-10s %s\n' profiles "${profs:-none}"
    printf '%-10s %s\n' "base save" "$([ "$base" = 1 ] && echo "$BASE_SAVE_NAME present" || echo "absent — build with: skytest setup-save")"
    printf '%-10s %s\n' session "$([ -n "$sess_pid" ] && echo "live test session (pid $sess_pid)" || echo "no test session")"
    echo
    echo "Next steps:"
    if [ "$tgt" = test ] && [ -n "$sess_pid" ]; then
      echo "  skytest stop              end the live test session + restore Data → full"
      echo "  skytest shot <out.png>    screenshot it    |    skytest drive …   inject input"
    elif [ "$tgt" = test ]; then
      echo "  skytest normal            recover: force Data → full after an interrupted test"
    fi
    echo "  skytest test <mod>        start a drivable test session"
    echo "  skytest play              launch the full modded game"
  else
    printf '%-10s not migrated (Data is the original real directory)\n' state
    echo
    echo "Next steps:"
    echo "  skytest init              preview the one-time migration (read-only)"
    echo "  skytest play              launch the full modded game as-is"
  fi
}

cmd_uninstall() {
  if [ ! -L "$DATA" ]; then say "already uninstalled — Data is the original real directory."; return 0; fi
  guard_no_live_session   # uninstall mv's FULL back over Data — same unpark hazard
  guard_no_running_game
  [ -d "$FULL" ] || die "missing $FULL -- not safe to uninstall automatically."
  rm "$DATA"
  mv -T "$FULL" "$DATA"
  rm -rf "$VANILLA" "$TEST"
  restore_plugins
  say "reverted: original Data/ restored, profiles removed."
}

# --- help --------------------------------------------------------------------

cmd_help() {
  cat <<'EOF'
skytest — isolated Skyrim SE mod-test launcher (symlink-profile based)

Usage: skytest <verb> [args]      (no verb → status)

Verbs:
  status            show current profile state + live test session [--json]
  init              preview the one-time migration (read-only)  [--commit --full --json]
  setup-save        build the base test save (vanilla launch)
  test <mod>        start a drivable gamescope test session      [--with a.dll,b.dll] [--headless]
  ready [secs]      block until the test session is in-world (probe poll)
  shot [out.png]    screenshot the test session       [cropWxH+X+Y] [scaleWxH]
  drive <cmd> …     inject input (tap|seq|key|click|abs|rel|raw)
  stop              tear down the test session + restore Data → full
  play              launch the full modded game (fast path, blocking, not drivable)
  normal            force Data → full (recover after a crash)
  uninstall         revert to the original real Data/ directory

  test = a detached, drivable gamescope session (visible by default; --headless for no
  window). It does NOT block: run shot/drive/ready as follow-up commands, then `stop` to
  end + restore. play/normal stay the bare direct path. <mod> is also accepted bare:
  `skytest path/to/mod` == `skytest test path/to/mod`. Run `skytest <verb> --help` for examples.
EOF
}

verb_help() {
  case "$1" in
    status) cat <<'EOF'
skytest status — show current profile state (default when no verb is given)
  --json    machine-readable
Examples:
  skytest status
  skytest status --json
EOF
;;
    init) cat <<'EOF'
skytest init — classify Data into vanilla/mod split; preview or apply migration
  --commit  perform the one-time migration (mv Data→full, symlink, build vanilla)
  --full    list every excluded mod plugin (default shows only the count)
  --json    machine-readable
Examples:
  skytest init
  skytest init --full
  skytest init --commit
EOF
;;
    setup-save) cat <<'EOF'
skytest setup-save — launch vanilla to build the base test save (SkytestBase)
At the menu: console `coc qasmoke`, place fixtures, `save SkytestBase`, then quit.
Examples:
  skytest setup-save
EOF
;;
    test) cat <<'EOF'
skytest test <mod> — start a drivable gamescope test session (vanilla + one mod;
boots into the base save if present). DETACHED: returns once in-world so you can
drive it with shot/drive/ready, then `skytest stop` to end + restore Data → full.
  <mod>        a Data-shaped folder, or a single .dll/.esp/.esl/.esm file
  --with a,b   extra framework DLLs to pull from the full profile (prefix match)
  --headless   no window (offscreen render); default is a window nested in Hyprland
  --sdl        visible fallback if --backend wayland misbehaves under Hyprland
Examples:
  skytest test build/MyMod                    # visible, drivable
  skytest test build/MyMod.dll --headless     # invisible, drivable
  skytest test build/MyMod.dll --with SKSE,po3_
  skytest build/MyMod.dll        # bare shortcut, identical to `test`
Then:
  skytest ready                  # block until in-world
  skytest shot /tmp/a.png        # capture a frame
  skytest drive seq down down enter
  skytest stop                   # end + restore Data → full
EOF
;;
    ready) cat <<'EOF'
skytest ready [timeout] — block until the running test session is in-world
(polls SkytestProbe status for inWorld:true). Default timeout 180s.
Exit: 0 = in-world, 1 = timed out, 2 = session died.
Examples:
  skytest ready
  skytest ready 240
EOF
;;
    shot) cat <<'EOF'
skytest shot [out.png] [cropWxH+X+Y] [scaleWxH] — screenshot the test session
(SIGUSR2 → newest gamescope AVIF → PNG). Default out: /tmp/sky-shot.png.
Examples:
  skytest shot /tmp/a.png
  skytest shot /tmp/crop.png 400x200+880+440
EOF
;;
    drive) cat <<'EOF'
skytest drive <cmd> … — inject input into the test session via libei (isolated to it).
  tap <key>            press+release one key            (e.g. drive tap enter)
  seq <key> …          tap several keys in order        (e.g. drive seq down down enter)
  key <key> <0|1>      hold(1)/release(0) one key
  click [<x> <y>]      click at (x,y), or at current cursor if omitted
  abs <x> <y>          move cursor to pixel (x,y)
  rel <dx> <dy>        relative pointer move (1 unit = 1 px)
  raw <eidriver args>  pass through verbatim
Keys: esc enter tab space backspace up down left right pageup pagedown home end
      tilde/console e r m w a s d f y n j i
Examples:
  skytest drive seq down down enter
  skytest drive click 1195 556
EOF
;;
    stop) cat <<'EOF'
skytest stop — tear down the running gamescope test session and restore Data → full
(+ Plugins.txt). Kills by gamescope session, so a real game in the same prefix is safe.
Examples:
  skytest stop
EOF
;;
    play) cat <<'EOF'
skytest play — launch the full modded game over the fast direct SKSE path
Examples:
  skytest play
EOF
;;
    normal) cat <<'EOF'
skytest normal — force Data → full (recover after an interrupted test or crash)
Examples:
  skytest normal
EOF
;;
    uninstall) cat <<'EOF'
skytest uninstall — revert Data to the original real directory, remove profiles
Examples:
  skytest uninstall
EOF
;;
    *) cmd_help ;;
  esac
}

# --- dispatch ----------------------------------------------------------------

# tool-level help
case "${1:-}" in help|--help|-h) cmd_help; exit 0 ;; esac

# per-verb help: `skytest <verb> --help`
case "${1:-}" in
  status|init|setup-save|test|ready|shot|drive|stop|play|normal|uninstall)
    case "${2:-}" in --help|-h) verb_help "$1"; exit 0 ;; esac ;;
esac

case "${1:-}" in
  ""|status)    cmd_status "${2:-}" ;;
  init)         shift; cmd_init "$@" ;;
  setup-save)   cmd_setup_save ;;
  test)         shift; cmd_test "$@" ;;
  ready)        shift; cmd_ready "$@" ;;
  shot)         shift; cmd_shot "$@" ;;
  drive)        shift; cmd_drive "$@" ;;
  stop)         cmd_stop ;;
  play)         cmd_play ;;
  normal)       cmd_normal ;;
  uninstall)    cmd_uninstall ;;
  -*)           usage_err "unknown option: $1" "skytest help" ;;
  *)            cmd_test "$@" ;;   # bare positional = mod-path shortcut for `test`
esac
