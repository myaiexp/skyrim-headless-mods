EOF
;;
    *) cmd_help ;;
  esac
}

# --- dispatch ----------------------------------------------------------------

# tool-level help
case "${1:-}" in help|--help|-h) cmd_help; exit 0 ;; esac

# per-verb help: `skytest <verb> --help`
case "${1:-}" in
  status|init|setup-save|test|replay|ready|shot|drive|stop|play|playtest|normal|uninstall)
    case "${2:-}" in --help|-h) verb_help "$1"; exit 0 ;; esac ;;
esac

# Mutex (finding #7): take the cross-invocation lock for verbs that mutate a profile, swap
# Data, or write the pidfile. Read-only verbs (status/ready/shot/drive) skip it. init and
# replay are conditional — `init --commit` mutates but bare `init` is a preview, and
# `replay --dry-run` is a pure lint — so THEY acquire_lock internally at the mutation point,
# not here.
case "${1:-}" in
  setup-save|test|stop|play|playtest|normal|uninstall) acquire_lock ;;
  ""|status|init|replay|ready|shot|drive) ;;  # read-only (init/replay self-lock at mutation)
  -*) ;;  # stray unknown option — usage_err in the next block, no lock needed
  *)  acquire_lock ;;  # bare positional = mod-path shortcut for `test` (mutating)
esac

case "${1:-}" in
  ""|status)    cmd_status "${2:-}" ;;
  init)         shift; cmd_init "$@" ;;
  setup-save)   cmd_setup_save ;;
  test)         shift; cmd_test "$@" ;;
  replay)       shift; cmd_replay "$@" ;;
  ready)        shift; cmd_ready "$@" ;;
  shot)         shift; cmd_shot "$@" ;;
  drive)        shift; cmd_drive "$@" ;;
  stop)         cmd_stop ;;
  play)         cmd_play ;;
  playtest)     shift; cmd_playtest "$@" ;;
  normal)       cmd_normal ;;
  uninstall)    cmd_uninstall ;;
  -*)           usage_err "unknown option: $1" "skytest help" ;;
  *)            cmd_test "$@" ;;   # bare positional = mod-path shortcut for `test`
esac
