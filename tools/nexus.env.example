# tools/nexus config — copy to `tools/nexus.env` (git-ignored) and fill in.
#   cp tools/nexus.env.example tools/nexus.env
# The tool auto-sources tools/nexus.env. Keep your real key out of git: nexus.env
# is ignored; this .example file is not (it has no secret).

# Personal API key — https://www.nexusmods.com/users/myaccount?tab=api
NEXUS_API_KEY=

# Optional: mods shown in the no-arg `nexus` grid (space-separated game:id)
NEXUS_MODS="skyrimspecialedition:182628"

# Optional: default game domain when omitted (else skyrimspecialedition)
# NEXUS_GAME=skyrimspecialedition
