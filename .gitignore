# .NET build output (restored from NuGet on first build)
bin/
obj/

# Papyrus compiler scratch (wine prefix is external; nothing to track here)
*.tmp

# Local Nexus API config for `tools/nexus` — holds your API key + watchlist.
# (nexus.env.example IS tracked; the real nexus.env / nexus.mods are not.)
tools/nexus.env
tools/nexus.mods

# SKSE C++ plugin build output (CMake + FetchContent deps; large, regenerated)
mods/*/build/
mods/*/plugin/build/

# Release packaging output (FOMOD staging + zip; regenerated by a mod's package.sh)
mods/*/dist/

# Working source backups (e.g. pre-cleanup probe builds kept locally)
*.bak

# skytest's compiled libei input client (rebuild with skytest/eidriver/build.sh)
skytest/eidriver/eidriver

# Third-party Papyrus source we must NOT redistribute (Bethesda / SKSE IP).
# Populate locally from your own game + SKSE install — see tools/papyrus-sources/README.md.
# (skyui/ is intentionally NOT ignored: SkyUI is open-source and redistributable.)
tools/papyrus-sources/vanilla/
tools/papyrus-sources/skse/
tools/papyrus-sources/TESV_Papyrus_Flags.flg

# Bethesda's Creation Kit Papyrus compiler binary + its DLLs — also third-party IP.
# Populate from your own game install — see tools/papyrus-compiler/README.md.
tools/papyrus-compiler/*
!tools/papyrus-compiler/README.md

# Ghidra reverse-engineering workspace: project data (.rep/.gpr) + logs are large
# and contain disassembly of Bethesda's SkyrimSE.exe (third-party IP) — never commit.
# The headless scripts under tools/ghidra/scripts/ ARE committed.
tools/ghidra/projects/
tools/ghidra/*.log
tools/ghidra/*.out

# Disassembly dumps of SkyrimSE.exe (third-party IP) — never commit.
tools/ghidra/out/

tools/ghidra/.venv/

# Steamless unpacker + the SkyrimSE.exe copy/unpacked output (third-party + game IP).
tools/ghidra/.steamless/
